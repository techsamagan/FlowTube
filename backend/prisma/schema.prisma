// FlowTube — Prisma schema
// Full schema per spec. The vertical slice exercises User, GoogleAccount,
// YoutubeChannel and Video; the remaining models are defined so migrations
// and later features (analysis engine, scheduler) drop in without churn.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Supabase: DATABASE_URL = pooled connection (PgBouncer, port 6543).
  // DIRECT_URL = direct connection (port 5432) used for migrations / db push.
  // For a plain local Postgres, point both at the same URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VideoStatus {
  generating
  ready
  uploading
  published
  failed
}

enum PatternType {
  hook
  structure
  topic
  timing
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  // scrypt$<saltHex>$<hashHex> — null for demo/mock users (passwordless).
  passwordHash   String?
  createdAt      DateTime        @default(now())
  googleAccounts GoogleAccount[]
}

model GoogleAccount {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  googleSub   String  @unique // Google account subject id
  email       String
  displayName String?
  avatarUrl   String?

  // Encrypted at rest in real mode (see services/crypto). Mock mode stores a marker.
  refreshTokenEnc String?
  accessToken     String?
  tokenExpiresAt  DateTime?

  channels  YoutubeChannel[]
  createdAt DateTime         @default(now())
}

model YoutubeChannel {
  id String @id @default(cuid())

  googleAccount   GoogleAccount @relation(fields: [googleAccountId], references: [id], onDelete: Cascade)
  googleAccountId String

  channelId       String  @unique // real YouTube channel id, or "pending:<cuid>" before manual creation
  name            String
  handle          String?
  niche           String
  language        String  @default("English")
  // What this channel is about. Drives on-brand script generation AND
  // biases trend recommendations toward this channel's actual focus.
  description     String  @default("")
  subscriberCount Int     @default(0)
  videoCount      Int     @default(0)
  viewCount       BigInt  @default(0)

  // Learned viral patterns for THIS channel (see spec "VIRAL DNA per channel")
  viralDNA Json?

  isMonetized        Boolean @default(false)
  monetizationStatus String  @default("not_eligible")

  // Set when this channel was AI-proposed for an account that had none yet.
  isAiProposed   Boolean @default(false)
  aiIdentity     Json? // suggested name/handle/desc/avatarPrompt/avatarUrl/bannerUrl
  setupCompleted Boolean @default(false)

  videos          Video[]
  viralPatterns   ViralPattern[]
  competitorScans CompetitorVideo[]
  calendarEntries CalendarEntry[]

  createdAt DateTime @default(now())
}

model Video {
  id String @id @default(cuid())

  channel   YoutubeChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String

  script       String // full script with [VISUAL CUE] / [TEXT POPUP] markers
  scriptMeta   Json? // sections, viralScore, hook analysis
  voiceoverUrl String?
  videoUrl     String?
  thumbnailUrl String?

  title       String?
  description String?
  tags        String[] @default([])

  // "short" (10-30s vertical) or "long" (4-10 min). Drives the script
  // blueprint, render length and B-roll count.
  format      String      @default("short")
  // AI pre-upload quality gate result: { verdict, score, reasons[] }.
  reviewMeta  Json?

  status      VideoStatus @default(generating)
  scheduledAt DateTime?
  publishedAt DateTime?

  youtubeVideoId String?

  analytics    VideoAnalytics?
  calendarEntry CalendarEntry?
  createdAt    DateTime        @default(now())
}

// A planned post on a channel's content calendar. Created manually by the
// user or generated by AI from the channel's viral DNA + best posting times.
// Becomes a Video once generated.
model CalendarEntry {
  id String @id @default(cuid())

  channel   YoutubeChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String

  scheduledFor DateTime
  topic        String
  format       String  @default("short") // "short" | "long"
  notes        String  @default("")
  source       String  @default("manual") // "manual" | "ai"
  // planned → generating → ready → publishing → published, or failed.
  // "ready" = video rendered + approved, waiting for scheduled publish time.
  status       String  @default("planned")
  // "manual" = wait for user; "auto" = scheduler renders + uploads at scheduledFor.
  autoMode     String  @default("manual")
  // Last failure reason, surfaced in the UI for retry.
  lastError    String?

  video   Video?  @relation(fields: [videoId], references: [id], onDelete: SetNull)
  videoId String? @unique

  createdAt DateTime @default(now())
}

model VideoAnalytics {
  id String @id @default(cuid())

  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoId String @unique

  views               Int   @default(0)
  likes               Int   @default(0)
  shares              Int   @default(0)
  comments            Int   @default(0)
  subscribersGained   Int   @default(0)
  averageViewDuration Float @default(0) // seconds
  retentionRate       Float @default(0) // averageViewPercentage 0-100
  loopRate            Float @default(0) // % who watched > 100%
  swipeAwayRate       Float @default(0)
  impressions         Int   @default(0)
  clickThroughRate    Float @default(0)

  isViral   Boolean  @default(false) // retentionRate > 70 OR loopRate > 100
  fetchedAt DateTime @default(now())
}

model ViralPattern {
  id String @id @default(cuid())

  channel   YoutubeChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String

  patternType PatternType
  pattern     Json
  confidence  Float       @default(0)
  occurrences Int         @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NicheTemplate {
  id          String   @id @default(cuid())
  niche       String   @unique
  hookStyles  String[] @default([])
  topicIdeas  String[] @default([])
  toneGuide   String
  avoidList   String[] @default([])
  createdAt   DateTime @default(now())
}

model CompetitorVideo {
  id String @id @default(cuid())

  channel   YoutubeChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String // OUR channel this competitor scan is attached to

  competitorChannelId String
  title               String
  views               Int     @default(0)
  retentionEstimate   Float   @default(0)
  hookText            String?
  duration            Int     @default(0)
  tags                String[] @default([])

  scannedAt DateTime @default(now())
}
