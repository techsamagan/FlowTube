# ── Mode ─────────────────────────────────────────────────────────────
# true  = no external API calls, realistic mock data (default)
# false = use the real keys below
MOCK_MODE=true

PORT=4000

# ── Database (Supabase) / Queue ──────────────────────────────────────
# Supabase → Project Settings → Database → Connection string:
#   DATABASE_URL = "Transaction pooler" URI (host ...pooler..., port 6543)
#                  append ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = "Direct connection" URI (port 5432) — used for migrations
# Example:
#   DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#   DIRECT_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Local Postgres fallback: set both to the same localhost URL.
DATABASE_URL=
DIRECT_URL=
REDIS_URL=redis://localhost:6379

# ── Google OAuth (YouTube) ───────────────────────────────────────────
# Fill these to make "+ Connect Google account" pull REAL channels.
# Works even with MOCK_MODE=true (AI stays mocked, channels are real).
# Google Cloud → APIs&Services: enable "YouTube Data API v3",
#   create OAuth client (type: Web application),
#   Authorized redirect URI = the GOOGLE_REDIRECT_URI below,
#   add your Google address as a Test user on the OAuth consent screen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Encrypts Google refresh tokens at rest (AES-256-GCM). Use any long random
# string in production; falls back to NEXTAUTH_SECRET if unset.
TOKEN_ENC_KEY=

# ── AI / Media ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY: real Claude scripts/metadata/recommendations.
#   Requires MOCK_MODE=false to take effect.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
# YOUTUBE_API_KEY: real trend/competitor search (Google Cloud → API key,
#   YouTube Data API v3 enabled). Works independently of OAuth & MOCK_MODE.
YOUTUBE_API_KEY=
ELEVENLABS_API_KEY=
PEXELS_API_KEY=
# PIXABAY_API_KEY: royalty-free background music (Pixabay license — safe for
#   monetized YouTube, no attribution, NOT Content-ID flagged). No key →
#   videos render with NO music (never copyrighted/trending audio).
PIXABAY_API_KEY=

# ── Storage (S3 / Cloudflare R2) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ── App auth (NextAuth.js) ───────────────────────────────────────────
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000
